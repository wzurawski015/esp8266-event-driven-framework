# Generic ESP8266 target: the host USB-UART bridge is intentionally unknown.
# Use FW_ESPPORT or target_usb_uart.local.profile for deterministic flashing.
EV_TARGET_NAME="esp8266_generic_dev"
EV_TARGET_USB_UART_BRIDGE="unknown / user-provided USB-UART"
EV_TARGET_USB_VID=""
EV_TARGET_USB_PID=""
EV_TARGET_USB_SERIAL=""
EV_TARGET_SERIAL_BY_ID_PATTERN=""
EV_TARGET_FLASH_BAUD="115200"
EV_TARGET_MONITOR_BAUD="115200"
EV_TARGET_RESET_MODE="default_reset"
EV_TARGET_FLASH_BEFORE="default_reset"
EV_TARGET_FLASH_AFTER="hard_reset"
EV_TARGET_PORT_HINT=""
