sdk_flash_common() {
  run_in_sdk_with_device \
    sh -lc '
      set -eu
      if [ ! -f "$EV_SDK_PROJECT/sdkconfig" ]; then
        make -C "$EV_SDK_PROJECT" SDKCONFIG_DEFAULTS=sdkconfig.defaults defconfig
      fi

      attempt=1

      while [ "$attempt" -le "$FLASH_RETRIES" ]; do
        log_file=$(mktemp)
        stream_dir=$(mktemp -d)
        stream_fifo="$stream_dir/flash.out"
        status=0
        retryable=0
        stream_pid=

        mkfifo "$stream_fifo"

        echo "note: flash attempt $attempt/$FLASH_RETRIES on $ESPPORT ..." >&2
        echo "note: live flash output is mirrored below; if the line stalls at Connecting...., the current esptool handshake is genuinely still in progress." >&2

        tee "$log_file" <"$stream_fifo" >&2 &
        stream_pid=$!

        PYTHONUNBUFFERED=1 make -C "$EV_SDK_PROJECT" \
          ESPPORT="$ESPPORT" \
          ESPTOOLPY_BEFORE="$FLASH_BEFORE" \
          ESPTOOLPY_AFTER="$FLASH_AFTER" \
          flash >"$stream_fifo" 2>&1 || status=$?

        wait "$stream_pid" 2>/dev/null || true
        rm -rf "$stream_dir"

        if grep -Eiq "setDTR|setRTS|TIOCMBIC|TIOCMBIS|Input/output error|Errno 5|Failed to connect|Timed out waiting for packet header|Invalid head of packet" "$log_file"; then
          retryable=1
          echo "note: serial auto-reset or bootloader handshake failed on $ESPPORT (attempt $attempt/$FLASH_RETRIES)." >&2
          echo "note: this is a known Docker/WSL2 USB-serial edge case." >&2
          echo "note: if retries do not help, use ./tools/fw sdk-flash-manual" >&2
          echo "note: after putting the board into ROM bootloader mode manually." >&2
        fi

        rm -f "$log_file"

        if [ "$status" -eq 0 ]; then
          exit 0
        fi

        if [ "$retryable" -ne 1 ] || [ "$attempt" -ge "$FLASH_RETRIES" ]; then
          exit "$status"
        fi

        echo "note: retrying flash in ${FLASH_RETRY_DELAY_S}s..." >&2
        sleep "$FLASH_RETRY_DELAY_S"
        attempt=$((attempt + 1))
      done

      exit 1
    '
}

sdk_flash() {
  sdk_flash_common
}

sdk_flash_manual() {
  echo "note: sdk-flash-manual skips esptool-managed auto-reset before and after flashing." >&2
  echo "note: put the board into ROM bootloader mode manually before flashing." >&2
  run_in_sdk_with_device \
    sh -lc '
      set -eu
      if [ ! -f "$EV_SDK_PROJECT/sdkconfig" ]; then
        make -C "$EV_SDK_PROJECT" SDKCONFIG_DEFAULTS=sdkconfig.defaults defconfig
      fi

      jobs=$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)
      make -C "$EV_SDK_PROJECT" -j"$jobs"

      project_name=$(sed -n "s/^PROJECT_NAME[[:space:]]*:=[[:space:]]*//p" "$EV_SDK_PROJECT/Makefile" | head -n 1 | sed "s/[[:space:]]*$//")

      if [ -z "$project_name" ]; then
        echo "error: could not derive PROJECT_NAME from $EV_SDK_PROJECT/Makefile" >&2
        exit 1
      fi

      build_dir="$EV_SDK_PROJECT/build"
      boot_bin="$build_dir/bootloader/bootloader.bin"
      part_bin="$build_dir/partitions_singleapp.bin"
      app_bin="$build_dir/${project_name}.bin"

      for artifact in "$boot_bin" "$part_bin" "$app_bin"; do
        if [ ! -f "$artifact" ]; then
          echo "error: missing flash artifact: $artifact" >&2
          exit 1
        fi
      done

      python3 "$IDF_PATH/components/esptool_py/esptool/esptool.py" \
        --chip esp8266 \
        --port "$ESPPORT" \
        --baud 115200 \
        --before no_reset \
        --after no_reset \
        write_flash -z --flash_mode dio --flash_freq 40m --flash_size 2MB \
        0x0 "$boot_bin" \
        0x10000 "$app_bin" \
        0x8000 "$part_bin"
    '
  echo "note: flashing finished without automatic reset; press RESET to boot the new app." >&2
}


