# Project-generated outputs
/build/
/out/
/coverage/
/dist/
/htmlcov/

# ESP8266 RTOS SDK target-local generated state
/adapters/esp8266_rtos_sdk/targets/*/build/
/adapters/esp8266_rtos_sdk/targets/*/sdkconfig
/adapters/esp8266_rtos_sdk/targets/*/sdkconfig.old

# Developer-local board secrets
/bsp/*/board_secrets.local.h

# Generated documentation
/docs/generated/*
!/docs/generated/.gitkeep

# Runtime logs and captures
/log/
/logs/

# Native / embedded build artifacts
*.o
*.obj
*.lo
*.la
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out

# Coverage / profiling / sanitizer outputs
*.gcda
*.gcno
*.gcov
*.profraw
*.profdata
.coverage
.coverage.*

# Tooling and local developer environment
/compile_commands.json
/.cache/
/.clangd/
/.vscode/
/.idea/
/.vs/
/.direnv/

# Python / tooling caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.venv/
venv/
env/

# C / C++ navigation databases
/tags
/TAGS
cscope.*

# Editor / OS noise
*~
*.swp
*.swo
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# Patch files and system artifacts
*.patch
*.diff
*:Zone.Identifier

# Developer-local USB-UART profile overrides
/adapters/esp8266_rtos_sdk/targets/*/target_usb_uart.local.profile
