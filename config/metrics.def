// Metric catalog single source of truth.
//
// Format:
// EV_METRIC(METRIC_ID, KIND, "summary")

EV_METRIC(EV_METRIC_POST_OK, counter, "Successful event posts")
EV_METRIC(EV_METRIC_POST_DROPPED, counter, "Dropped events")
EV_METRIC(EV_METRIC_MAILBOX_HIGH_WATER, gauge, "Highest observed mailbox usage")
EV_METRIC(EV_METRIC_POOL_HIGH_WATER, gauge, "Highest observed memory pool usage")

EV_METRIC(EV_METRIC_DELIVERY_ATTEMPTED, counter, "Attempted actor-registry deliveries")
EV_METRIC(EV_METRIC_DELIVERY_OK, counter, "Successful actor-registry deliveries")
EV_METRIC(EV_METRIC_DELIVERY_FAILED, counter, "Failed actor-registry deliveries")
EV_METRIC(EV_METRIC_ACTOR_ENQUEUED, counter, "Messages accepted into actor mailboxes")
EV_METRIC(EV_METRIC_ACTOR_HANDLER_ERRORS, counter, "Actor handler failures")
EV_METRIC(EV_METRIC_ACTOR_PENDING_HIGH_WATER, gauge, "Highest observed pending count per actor runtime")
EV_METRIC(EV_METRIC_ACTOR_PUMP_CALLS, counter, "Bounded drain invocations per actor runtime")
EV_METRIC(EV_METRIC_ACTOR_PUMP_BUDGET_HITS, counter, "Bounded drain runs that stopped because budget was exhausted")
EV_METRIC(EV_METRIC_DOMAIN_PUMP_CALLS, counter, "Cooperative domain-pump invocations")
EV_METRIC(EV_METRIC_DOMAIN_PUMP_EMPTY, counter, "Cooperative domain-pump runs with no pending work")
EV_METRIC(EV_METRIC_DOMAIN_PUMP_BUDGET_HITS, counter, "Cooperative domain-pump runs that exhausted the global budget")
EV_METRIC(EV_METRIC_SYSTEM_PUMP_CALLS, counter, "Multi-domain cooperative pump invocations")
EV_METRIC(EV_METRIC_SYSTEM_PUMP_EMPTY, counter, "Multi-domain cooperative pump runs with no pending work")
EV_METRIC(EV_METRIC_SYSTEM_PUMP_DOMAINS, counter, "Domain turns executed by the multi-domain cooperative pump")
EV_METRIC(EV_METRIC_SYSTEM_PUMP_MESSAGES, counter, "Messages processed by the multi-domain cooperative pump")
EV_METRIC(EV_METRIC_SYSTEM_PUMP_BUDGET_HITS, counter, "Multi-domain cooperative pump runs that exhausted the turn budget")
EV_METRIC(EV_METRIC_MAILBOX_OVERFLOW, counter, "Mailbox overflow events")
EV_METRIC(EV_METRIC_TIMER_SCHEDULED, counter, "Timers scheduled")
EV_METRIC(EV_METRIC_TIMER_CANCELLED, counter, "Timers cancelled")
EV_METRIC(EV_METRIC_TIMER_DUE, counter, "Timers due")
EV_METRIC(EV_METRIC_TIMER_PUBLISHED, counter, "Timer events published")
EV_METRIC(EV_METRIC_QUIESCENCE_ACCEPTED, counter, "Quiescence accepted")
EV_METRIC(EV_METRIC_QUIESCENCE_REJECTED, counter, "Quiescence rejected")
EV_METRIC(EV_METRIC_SLEEP_ACCEPTED, counter, "Sleep accepted")
EV_METRIC(EV_METRIC_SLEEP_REJECTED, counter, "Sleep rejected")
EV_METRIC(EV_METRIC_FAULT_EMITTED, counter, "Faults emitted")
EV_METRIC(EV_METRIC_FAULT_COALESCED, counter, "Faults coalesced")
EV_METRIC(EV_METRIC_TRACE_DROPPED, counter, "Trace records dropped")
EV_METRIC(EV_METRIC_NETWORK_PUBLISH_ACCEPTED, counter, "Network publishes accepted")
EV_METRIC(EV_METRIC_NETWORK_PUBLISH_REJECTED, counter, "Network publishes rejected")
EV_METRIC(EV_METRIC_NETWORK_PUBLISH_DROPPED, counter, "Network publishes dropped")
EV_METRIC(EV_METRIC_COMMAND_ACCEPTED, counter, "Commands accepted")
EV_METRIC(EV_METRIC_COMMAND_REJECTED, counter, "Commands rejected")
EV_METRIC(EV_METRIC_COMMAND_AUTH_FAILED, counter, "Command authentication failures")
EV_METRIC(EV_METRIC_ROUTE_DISABLED_SKIPPED, counter, "Disabled optional routes skipped by active-route delivery")
EV_METRIC(EV_METRIC_ROUTE_VALIDATION_REJECTED, counter, "Rejected active-route validation entries")
EV_METRIC(EV_METRIC_ROUTE_OPTIONAL_DISABLED, counter, "Optional routes disabled by board/profile capabilities")
EV_METRIC(EV_METRIC_ROUTE_QOS_CONFLICT, counter, "Routes rejected because QoS conflicts with module policy")
EV_METRIC(EV_METRIC_ROUTE_ACTIVE_TABLE_OVERFLOW, counter, "Active route table overflows")
EV_METRIC(EV_METRIC_INGRESS_HIGH_WATER, gauge, "Ingress sequence ring high-water level")
EV_METRIC(EV_METRIC_INGRESS_DROPPED, counter, "Ingress events dropped by bounded sequence ring")

