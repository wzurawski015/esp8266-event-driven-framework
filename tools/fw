  ./tools/fw shell-host
  ./tools/fw shell-docs
  ./tools/fw shell-sdk

  ./tools/fw sdk-ports
  ./tools/fw sdk-port-resolve
  ./tools/fw target-usb-profile-check
  ./tools/fw sdk-port-resolve-test

  ./tools/fw sdk-check
  ./tools/fw sdk-defconfig
  ./tools/fw sdk-menuconfig
  ./tools/fw sdk-build
  ./tools/fw sdk-memory-report
  ./tools/fw sdk-build-report
  ./tools/fw sdk-network-build-gate
  ./tools/fw sdk-clean-target
  ./tools/fw sdk-distclean
  ./tools/fw sdk-flash
  ./tools/fw sdk-flash-manual
  ./tools/fw sdk-monitor
  ./tools/fw sdk-simple-monitor

  ./tools/fw hil-i2c-build
  ./tools/fw hil-i2c-flash
  ./tools/fw hil-i2c-monitor
  ./tools/fw hil-i2c-run

  ./tools/fw hil-onewire-build
  ./tools/fw hil-onewire-flash
  ./tools/fw hil-onewire-monitor
  ./tools/fw hil-onewire-run

  ./tools/fw hil-wifi-build
