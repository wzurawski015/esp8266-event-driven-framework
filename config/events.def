// Event single source of truth.
//
// Format:
// EV_EVENT(EVENT_ID, PAYLOAD_KIND, "summary")

EV_EVENT(EV_BOOT_STARTED, EV_PAYLOAD_INLINE, "Bootstrap sequence started")
EV_EVENT(EV_BOOT_COMPLETED, EV_PAYLOAD_INLINE, "Bootstrap sequence completed")
EV_EVENT(EV_TICK_1S, EV_PAYLOAD_INLINE, "One-second system tick")
EV_EVENT(EV_STREAM_CHUNK_READY, EV_PAYLOAD_LEASE, "Streaming chunk ready for downstream processing")
EV_EVENT(EV_DIAG_SNAPSHOT_REQ, EV_PAYLOAD_INLINE, "Diagnostic snapshot requested")
EV_EVENT(EV_DIAG_SNAPSHOT_RSP, EV_PAYLOAD_LEASE, "Diagnostic snapshot prepared")
EV_EVENT(EV_OLED_DISPLAY_TEXT_CMD, EV_PAYLOAD_INLINE, "OLED display text command")
EV_EVENT(EV_OLED_COMMIT_FRAME, EV_PAYLOAD_LEASE, "OLED frame commit command")
EV_EVENT(EV_TIME_UPDATED, EV_PAYLOAD_INLINE, "RTC time updated from hardware clock")
EV_EVENT(EV_TEMP_UPDATED, EV_PAYLOAD_INLINE, "DS18B20 temperature updated from hardware sensor")
EV_EVENT(EV_TICK_100MS, EV_PAYLOAD_INLINE, "One-hundred-millisecond system tick")
EV_EVENT(EV_GPIO_IRQ, EV_PAYLOAD_INLINE, "Normalized GPIO interrupt sample")
EV_EVENT(EV_MCP23008_INPUT_CHANGED, EV_PAYLOAD_INLINE, "Normalized MCP23008 button input state changed")
EV_EVENT(EV_BUTTON_EVENT, EV_PAYLOAD_INLINE, "Logical user button event")
EV_EVENT(EV_PANEL_LED_SET_CMD, EV_PAYLOAD_INLINE, "Logical panel LED set command")
EV_EVENT(EV_MCP23008_READY, EV_PAYLOAD_INLINE, "MCP23008 startup sequencing completed")
EV_EVENT(EV_RTC_READY, EV_PAYLOAD_INLINE, "RTC actor became operational")
EV_EVENT(EV_OLED_READY, EV_PAYLOAD_INLINE, "OLED actor became operational")
EV_EVENT(EV_DS18B20_READY, EV_PAYLOAD_INLINE, "DS18B20 actor became operational")
EV_EVENT(EV_SYSTEM_READY, EV_PAYLOAD_INLINE, "System startup completed with capability snapshot")
EV_EVENT(EV_SYS_GOTO_SLEEP_CMD, EV_PAYLOAD_INLINE, "System deep sleep command")
EV_EVENT(EV_NET_WIFI_UP, EV_PAYLOAD_INLINE, "WiFi link became available")
EV_EVENT(EV_NET_WIFI_DOWN, EV_PAYLOAD_INLINE, "WiFi link went down")
EV_EVENT(EV_NET_MQTT_UP, EV_PAYLOAD_INLINE, "MQTT session became available")
EV_EVENT(EV_NET_MQTT_DOWN, EV_PAYLOAD_INLINE, "MQTT session went down")
EV_EVENT(EV_NET_MQTT_MSG_RX, EV_PAYLOAD_INLINE, "Bounded MQTT message received")
EV_EVENT(EV_NET_MQTT_MSG_RX_LEASE, EV_PAYLOAD_LEASE, "Leased MQTT message received")
EV_EVENT(EV_NET_TX_CMD, EV_PAYLOAD_INLINE, "Bounded MQTT publish command")
EV_EVENT(EV_FAULT_REPORTED, EV_PAYLOAD_COPY_FIXED, "Framework fault reported")
EV_EVENT(EV_ACTOR_LIFECYCLE_CHANGED, EV_PAYLOAD_COPY_FIXED, "Actor lifecycle state changed")
EV_EVENT(EV_ACTOR_READY, EV_PAYLOAD_COPY_FIXED, "Actor entered ready state")
EV_EVENT(EV_ACTOR_DEGRADED, EV_PAYLOAD_COPY_FIXED, "Actor entered degraded state")
EV_EVENT(EV_ACTOR_OFFLINE, EV_PAYLOAD_COPY_FIXED, "Actor entered offline state")
EV_EVENT(EV_ACTOR_SLEEP_READY, EV_PAYLOAD_COPY_FIXED, "Actor reports sleep-ready")
EV_EVENT(EV_ACTOR_FAULT, EV_PAYLOAD_COPY_FIXED, "Actor fault lifecycle event")
EV_EVENT(EV_CAPABILITY_UPDATED, EV_PAYLOAD_COPY_FIXED, "Capability snapshot updated")
EV_EVENT(EV_COMMAND_AUTH_FAILED, EV_PAYLOAD_INLINE, "Command authentication failed")
EV_EVENT(EV_COMMAND_ACCEPTED, EV_PAYLOAD_INLINE, "Command accepted")
EV_EVENT(EV_COMMAND_REJECTED, EV_PAYLOAD_INLINE, "Command rejected")

