// Wemos D1 Mini (ZY8266 / FT232) board pin map.
// Format:
// EV_BSP_PIN(LOGICAL_NAME, GPIO_NUM, "summary")
// EV_BSP_PIN_ANALOG(LOGICAL_NAME, "summary")
EV_BSP_PIN(PIN_UART0_TX, 1U, "UART0 TX via FT232 USB-UART bridge")
EV_BSP_PIN(PIN_UART0_RX, 3U, "UART0 RX via FT232 USB-UART bridge")
EV_BSP_PIN(PIN_STATUS_LED, 2U, "Module blue LED; active low")
EV_BSP_PIN(PIN_I2C0_SCL, 5U, "Primary I2C SCL on D1")
EV_BSP_PIN(PIN_I2C0_SDA, 4U, "Primary I2C SDA on D2")
EV_BSP_PIN(PIN_OPTIONAL_WAKE0, 16U, "Optional wake pin on D0")
EV_BSP_PIN(PIN_BOOTSTRAP0, 0U, "Bootstrap / flash pin on D3")
EV_BSP_PIN(PIN_SPI0_SCK, 14U, "Primary SPI clock on D5")
EV_BSP_PIN(PIN_SPI0_MISO, 12U, "Primary SPI MISO on D6")
EV_BSP_PIN(PIN_SPI0_MOSI, 13U, "Primary SPI MOSI on D7")
EV_BSP_PIN(PIN_OPTIONAL_SPI0_CS0, 15U, "Optional SPI chip-select on D8")
EV_BSP_PIN_ANALOG(PIN_ADC0_INPUT, "ADC0 / A0 input via on-board divider")
