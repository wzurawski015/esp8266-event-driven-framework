// Adafruit Feather HUZZAH ESP8266 board pin map.
// Format:
// EV_BSP_PIN(LOGICAL_NAME, GPIO_NUM, "summary")
// EV_BSP_PIN_ANALOG(LOGICAL_NAME, "summary")
EV_BSP_PIN(PIN_UART0_TX, 1U, "UART0 TX via USB-UART bridge")
EV_BSP_PIN(PIN_UART0_RX, 3U, "UART0 RX via USB-UART bridge")
EV_BSP_PIN(PIN_STATUS_LED, 0U, "On-board red system LED; active low")
EV_BSP_PIN(PIN_MODULE_LED, 2U, "Module blue LED; active low")
EV_BSP_PIN(PIN_I2C0_SDA, 4U, "Primary I2C SDA")
EV_BSP_PIN(PIN_I2C0_SCL, 5U, "Primary I2C SCL")
EV_BSP_PIN(PIN_SPI0_SCK, 14U, "Primary SPI clock")
EV_BSP_PIN(PIN_SPI0_MISO, 12U, "Primary SPI MISO")
EV_BSP_PIN(PIN_SPI0_MOSI, 13U, "Primary SPI MOSI")
EV_BSP_PIN(PIN_OPTIONAL_WAKE0, 16U, "Optional wake pin")
EV_BSP_PIN(PIN_BOOTSTRAP0, 15U, "Bootstrap-sensitive optional GPIO")
EV_BSP_PIN(PIN_OPTIONAL_GPIO12, 12U, "Optional GPIO12")
EV_BSP_PIN(PIN_OPTIONAL_GPIO13, 13U, "Optional GPIO13")
EV_BSP_PIN(PIN_OPTIONAL_GPIO14, 14U, "Optional GPIO14")
EV_BSP_PIN_ANALOG(PIN_ADC0_INPUT, "ADC0 / A0 input via on-board divider")
