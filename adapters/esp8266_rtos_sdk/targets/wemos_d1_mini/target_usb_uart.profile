# Host-side USB-UART profile for the Wemos D1 Mini ZY8266 variant.
# Common WCH CH340/CH341 VID/PID is used as a target hint.
EV_TARGET_NAME="wemos_d1_mini_zy8266"
EV_TARGET_USB_UART_BRIDGE="CH340 / CH341 / WCH USB-UART"
EV_TARGET_USB_VID="1a86"
EV_TARGET_USB_PID="7523"
EV_TARGET_USB_SERIAL=""
EV_TARGET_SERIAL_BY_ID_PATTERN="*/usb-1a86*USB*Serial*"
EV_TARGET_FLASH_BAUD="115200"
EV_TARGET_MONITOR_BAUD="115200"
EV_TARGET_RESET_MODE="default_reset"
EV_TARGET_FLASH_BEFORE="default_reset"
EV_TARGET_FLASH_AFTER="hard_reset"
EV_TARGET_PORT_HINT=""
