require_docker() {
  command -v "$DOCKER_BIN" >/dev/null 2>&1 || {
    echo "error: docker binary not found: $DOCKER_BIN" >&2
    exit 1
  }
}

require_sdk_project() {
  if [ ! -f "$ROOT_DIR/$SDK_PROJECT_DIR_REL/Makefile" ]; then
    echo "error: SDK project not found at $ROOT_DIR/$SDK_PROJECT_DIR_REL" >&2
    echo "set FW_SDK_PROJECT_DIR to a valid relative project path" >&2
    exit 1
  fi
}

require_sdkconfig_file() {
  require_sdk_project
  if [ ! -f "$ROOT_DIR/$SDK_PROJECT_DIR_REL/sdkconfig" ]; then
    echo "error: sdkconfig missing for $SDK_PROJECT_DIR_REL" >&2
    echo "run ./tools/fw sdk-defconfig or ./tools/fw sdk-build first" >&2
    exit 1
  fi
}

serial_port_candidates() {
  found=0
  for path in /dev/ttyUSB* /dev/ttyACM*; do
    if [ -e "$path" ]; then
      printf '%s\n' "$path"
      found=1
    fi
  done
  [ "$found" -eq 1 ]
}

serial_by_id_candidates() {
  found=0
  for path in /dev/serial/by-id/*; do
    if [ -e "$path" ]; then
      printf '%s\n' "$path"
      found=1
    fi
  done
  [ "$found" -eq 1 ]
}

candidate_count() {
  printf '%s\n' "$1" | sed '/^$/d' | wc -l | tr -d '[:space:]'
}

candidate_first() {
  printf '%s\n' "$1" | sed '/^$/d' | sed -n '1p'
}

resolve_serial_symlink() {
  if command -v readlink >/dev/null 2>&1; then
    readlink -f "$1" 2>/dev/null || printf '%s\n' "$1"
  else
    printf '%s\n' "$1"
  fi
}

sdk_target_name_from_project_dir() {
  basename "$SDK_PROJECT_DIR_REL"
}

sdk_target_profile_path() {
  printf '%s/%s/target_usb_uart.profile\n' "$ROOT_DIR" "$SDK_PROJECT_DIR_REL"
}

sdk_target_local_profile_path() {
  printf '%s/%s/target_usb_uart.local.profile\n' "$ROOT_DIR" "$SDK_PROJECT_DIR_REL"
}

sdk_clear_target_usb_uart_profile() {
  EV_TARGET_NAME="$(sdk_target_name_from_project_dir)"
  EV_TARGET_USB_UART_BRIDGE="unknown"
  EV_TARGET_USB_VID=""
  EV_TARGET_USB_PID=""
  EV_TARGET_USB_SERIAL=""
  EV_TARGET_SERIAL_BY_ID_PATTERN=""
  EV_TARGET_FLASH_BAUD=""
  EV_TARGET_MONITOR_BAUD=""
  EV_TARGET_RESET_MODE=""
  EV_TARGET_FLASH_BEFORE=""
  EV_TARGET_FLASH_AFTER=""
  EV_TARGET_PORT_HINT=""
}

sdk_load_target_usb_uart_profile() {
  sdk_clear_target_usb_uart_profile
  profile_path=$(sdk_target_profile_path)
  local_profile_path=$(sdk_target_local_profile_path)

  if [ -f "$profile_path" ]; then
    . "$profile_path"
  fi

  if [ -f "$local_profile_path" ]; then
    . "$local_profile_path"
  fi
}

sdk_apply_target_usb_uart_profile_defaults() {
  sdk_load_target_usb_uart_profile

  if [ -n "${EV_TARGET_MONITOR_BAUD:-}" ] && [ -z "${FW_MONITOR_BAUD+x}" ] && [ -z "${MONITORBAUD+x}" ]; then
    SDK_MONITOR_BAUD="$EV_TARGET_MONITOR_BAUD"
  fi
  if [ -n "${EV_TARGET_FLASH_BEFORE:-}" ] && [ -z "${FW_FLASH_BEFORE+x}" ]; then
    SDK_FLASH_BEFORE="$EV_TARGET_FLASH_BEFORE"
  fi
  if [ -n "${EV_TARGET_FLASH_AFTER:-}" ] && [ -z "${FW_FLASH_AFTER+x}" ]; then
    SDK_FLASH_AFTER="$EV_TARGET_FLASH_AFTER"
  fi
}

sdk_select_single_serial_candidate() {
  reason="$1"
  candidates="$2"
  count=$(candidate_count "$candidates")
  case "$count" in
    0)
      return 1
      ;;
    1)
      SDK_SERIAL_PORT=$(resolve_serial_symlink "$(candidate_first "$candidates")")
      return 0
      ;;
    *)
      echo "error: multiple serial devices matched $reason for target $EV_TARGET_NAME" >&2
      printf '%s\n' "$candidates" | sed '/^$/d' >&2
      echo "set FW_ESPPORT explicitly or add target_usb_uart.local.profile with EV_TARGET_USB_SERIAL, EV_TARGET_SERIAL_BY_ID_PATTERN, or EV_TARGET_PORT_HINT" >&2
      return 2
      ;;
  esac
}

sdk_match_serial_by_port_hint() {
  if [ -n "${EV_TARGET_PORT_HINT:-}" ] && [ -e "$EV_TARGET_PORT_HINT" ]; then
    SDK_SERIAL_PORT=$(resolve_serial_symlink "$EV_TARGET_PORT_HINT")
    return 0
  fi
  return 1
}

sdk_match_serial_by_id() {
  by_id=$(serial_by_id_candidates || true)
  matches=""

  if [ -n "${EV_TARGET_USB_SERIAL:-}" ]; then
    for path in $by_id; do
      base=$(basename "$path")
      if printf '%s\n' "$base" | grep -F "$EV_TARGET_USB_SERIAL" >/dev/null 2>&1; then
        matches="${matches}${path}
"
      fi
    done
    if sdk_select_single_serial_candidate "USB serial $EV_TARGET_USB_SERIAL" "$matches"; then
      return 0
    else
      rc=$?
      [ "$rc" -eq 2 ] && return 2
    fi
  fi

  matches=""
  if [ -n "${EV_TARGET_SERIAL_BY_ID_PATTERN:-}" ]; then
    for path in $by_id; do
      case "$path" in
        $EV_TARGET_SERIAL_BY_ID_PATTERN)
          matches="${matches}${path}
"
          ;;
      esac
    done
    if sdk_select_single_serial_candidate "by-id pattern $EV_TARGET_SERIAL_BY_ID_PATTERN" "$matches"; then
      return 0
    else
      rc=$?
      [ "$rc" -eq 2 ] && return 2
    fi
  fi

  return 1
}

sdk_match_serial_by_vid_pid() {
  if [ -z "${EV_TARGET_USB_VID:-}" ] || [ -z "${EV_TARGET_USB_PID:-}" ]; then
    return 1
  fi
  if ! command -v udevadm >/dev/null 2>&1; then
    return 1
  fi

  want_vid=$(printf '%s\n' "$EV_TARGET_USB_VID" | tr '[:upper:]' '[:lower:]')
  want_pid=$(printf '%s\n' "$EV_TARGET_USB_PID" | tr '[:upper:]' '[:lower:]')
  matches=""
  for path in $(serial_port_candidates || true); do
    props=$(udevadm info -q property -n "$path" 2>/dev/null || true)
    got_vid=$(printf '%s\n' "$props" | sed -n 's/^ID_VENDOR_ID=//p' | head -n 1 | tr '[:upper:]' '[:lower:]')
    got_pid=$(printf '%s\n' "$props" | sed -n 's/^ID_MODEL_ID=//p' | head -n 1 | tr '[:upper:]' '[:lower:]')
    if [ "$got_vid" = "$want_vid" ] && [ "$got_pid" = "$want_pid" ]; then
      matches="${matches}${path}
"
    fi
  done

  if sdk_select_single_serial_candidate "VID:PID ${EV_TARGET_USB_VID}:${EV_TARGET_USB_PID}" "$matches"; then
    return 0
  else
    rc=$?
    [ "$rc" -eq 2 ] && return 2
  fi

  return 1
}

resolve_serial_port() {
  if [ -n "$SDK_SERIAL_PORT" ]; then
    return 0
  fi

  sdk_apply_target_usb_uart_profile_defaults

  if sdk_match_serial_by_port_hint; then
    return 0
  fi
  if sdk_match_serial_by_id; then
    return 0
  else
    rc=$?
    [ "$rc" -eq 2 ] && return 1
  fi
  if sdk_match_serial_by_vid_pid; then
    return 0
  else
    rc=$?
    [ "$rc" -eq 2 ] && return 1
  fi

  candidates=$(serial_port_candidates || true)
  count=$(candidate_count "$candidates")

  case "$count" in
    1)
      SDK_SERIAL_PORT=$(candidate_first "$candidates")
      echo "note: target profile did not produce a unique match; using the only visible serial device: $SDK_SERIAL_PORT" >&2
      return 0
      ;;
    0)
      echo "error: no serial device found for target $EV_TARGET_NAME under /dev/serial/by-id, /dev/ttyUSB*, or /dev/ttyACM*" >&2
      echo "target profile: $(sdk_target_profile_path)" >&2
      echo "use ./tools/fw sdk-ports to inspect visible serial devices" >&2
      echo "or set FW_ESPPORT explicitly" >&2
      return 1
      ;;
    *)
      echo "error: multiple serial devices are visible and target profile did not resolve one unique port" >&2
      printf '%s\n' "$candidates" >&2
      echo "target profile: $(sdk_target_profile_path)" >&2
      echo "use /dev/serial/by-id, set FW_ESPPORT, or add target_usb_uart.local.profile" >&2
      return 1
      ;;
  esac
}

sdk_ports() {
  echo "serial device nodes:" >&2
  if serial_port_candidates; then
    :
  else
    echo "  (none under /dev/ttyUSB* or /dev/ttyACM*)" >&2
  fi
  echo "serial by-id links:" >&2
  if serial_by_id_candidates; then
    :
  else
    echo "  (none under /dev/serial/by-id)" >&2
  fi
}

sdk_port_resolve() {
  require_serial_port
  printf '%s\n' "$SDK_SERIAL_PORT"
}

require_serial_port() {
  resolve_serial_port || exit 1
  if [ ! -e "$SDK_SERIAL_PORT" ]; then
    echo "error: serial device not found: $SDK_SERIAL_PORT" >&2
    echo "use ./tools/fw sdk-ports to inspect visible serial devices" >&2
    echo "or set FW_ESPPORT explicitly" >&2
    exit 1
  fi
}

target_usb_profile_check() {
  failures=0
  for target_dir in "$ROOT_DIR"/adapters/esp8266_rtos_sdk/targets/*; do
    [ -d "$target_dir" ] || continue
    target_name=$(basename "$target_dir")
    profile="$target_dir/target_usb_uart.profile"
    if [ ! -f "$profile" ]; then
      echo "error: missing USB-UART profile for target: $target_name" >&2
      failures=$((failures + 1))
      continue
    fi
    (
      EV_TARGET_NAME=
      EV_TARGET_USB_UART_BRIDGE=
      EV_TARGET_FLASH_BAUD=
      EV_TARGET_MONITOR_BAUD=
      . "$profile"
      test -n "$EV_TARGET_NAME"
      test -n "$EV_TARGET_USB_UART_BRIDGE"
      test -n "$EV_TARGET_FLASH_BAUD"
      test -n "$EV_TARGET_MONITOR_BAUD"
    ) || {
      echo "error: invalid USB-UART profile: $profile" >&2
      failures=$((failures + 1))
    }
  done

  tracked_local=$(git -C "$ROOT_DIR" ls-files 'adapters/esp8266_rtos_sdk/targets/*/target_usb_uart.local.profile' 2>/dev/null || true)
  if [ -n "$tracked_local" ]; then
    echo "error: local USB-UART override profile is tracked by Git:" >&2
    printf '%s\n' "$tracked_local" >&2
    failures=$((failures + 1))
  fi

  if FW_ESPPORT=/dev/null ESPPORT= FW_SDK_PROJECT_DIR="$SDK_PROJECT_DIR_REL" "$0" sdk-port-resolve 2>/dev/null | grep -qx '/dev/null'; then
    :
  else
    echo "error: FW_ESPPORT override did not win in sdk-port-resolve" >&2
    failures=$((failures + 1))
  fi

  if [ "$failures" -ne 0 ]; then
    echo "EV_TARGET_USB_PROFILE_CHECK FAIL failures=$failures" >&2
    return 1
  fi
  echo "EV_TARGET_USB_PROFILE_CHECK PASS failures=0"
}

sdk_port_resolve_test() {
  FW_ESPPORT=/dev/null ESPPORT= FW_SDK_PROJECT_DIR="$SDK_PROJECT_DIR_REL" "$0" sdk-port-resolve | grep -qx '/dev/null'
  echo "EV_SDK_PORT_RESOLVE_TEST PASS"
}

build_host_image() {
  require_docker
  "$DOCKER_BIN" build \
    -f "$ROOT_DIR/docker/Dockerfile.host" \
    -t "$HOST_IMAGE" \
    "$ROOT_DIR"
}

build_docs_image() {
  require_docker
  "$DOCKER_BIN" build \
    -f "$ROOT_DIR/docker/Dockerfile.docs" \
    -t "$DOCS_IMAGE" \
    "$ROOT_DIR"
}

build_sdk_image() {
  require_docker
  "$DOCKER_BIN" build \
    -f "$ROOT_DIR/docker/Dockerfile.sdk" \
    -t "$SDK_IMAGE" \
    "$ROOT_DIR"
}
freertos_static_allocation_config_is_valid() {
  freertos_config="$1"

  static_count=$(grep -Ec '^[[:space:]]*#define[[:space:]]+configSUPPORT_STATIC_ALLOCATION[[:space:]]+1([[:space:]]|$)' "$freertos_config" || true)
  dynamic_count=$(grep -Ec '^[[:space:]]*#define[[:space:]]+configSUPPORT_DYNAMIC_ALLOCATION[[:space:]]+1([[:space:]]|$)' "$freertos_config" || true)

  [ "$static_count" -eq 1 ] && [ "$dynamic_count" -eq 1 ]
}

sdk_static_config_wrapper_script() {
  cat <<'SDK_STATIC_CONFIG_WRAPPER'
set -eu
freertos_static_allocation_config_is_valid() {
  freertos_config="$1"
  static_count=$(grep -Ec '^[[:space:]]*#define[[:space:]]+configSUPPORT_STATIC_ALLOCATION[[:space:]]+1([[:space:]]|$)' "$freertos_config" || true)
  dynamic_count=$(grep -Ec '^[[:space:]]*#define[[:space:]]+configSUPPORT_DYNAMIC_ALLOCATION[[:space:]]+1([[:space:]]|$)' "$freertos_config" || true)
  [ "$static_count" -eq 1 ] && [ "$dynamic_count" -eq 1 ]
}
ensure_freertos_static_allocation_config() {
  freertos_config="${IDF_PATH:?IDF_PATH is not set}/components/freertos/port/esp8266/include/freertos/FreeRTOSConfig.h"
  if [ ! -f "$freertos_config" ]; then
    echo "error: FreeRTOSConfig.h not found: $freertos_config" >&2
    return 1
  fi
  if freertos_static_allocation_config_is_valid "$freertos_config"; then
    return 0
  fi
  if [ ! -w "$freertos_config" ]; then
    echo "error: FreeRTOSConfig.h requires static-allocation injection but is not writable: $freertos_config" >&2
    echo "error: rebuild the SDK image or run sdk-check with permissions to update the SDK header" >&2
    return 1
  fi
  tmp_file="${freertos_config}.ev-static.$$"
  trap 'rm -f "$tmp_file"' HUP INT TERM EXIT
  sed '/EV_FREERTOS_STATIC_ALLOC_CONFIG_BEGIN/,/EV_FREERTOS_STATIC_ALLOC_CONFIG_END/d' "$freertos_config" \
    | sed \
        -e '/^[[:space:]]*#[[:space:]]*define[[:space:]][[:space:]]*configSUPPORT_STATIC_ALLOCATION[[:space:]]/d' \
        -e '/^[[:space:]]*#[[:space:]]*define[[:space:]][[:space:]]*configSUPPORT_DYNAMIC_ALLOCATION[[:space:]]/d' \
      > "$tmp_file"
  cat "$tmp_file" > "$freertos_config"
  cat >> "$freertos_config" <<'FREERTOS_STATIC_ALLOC_CONFIG'

/* EV_FREERTOS_STATIC_ALLOC_CONFIG_BEGIN
 * Project environment hardening:
 *   - configSUPPORT_STATIC_ALLOCATION enables application-provided
 *     Idle/Timer task memory hooks.
 *   - configSUPPORT_DYNAMIC_ALLOCATION remains enabled only as an ESP8266
 *     vendor SDK bootstrap compatibility bridge.
 *   - This block does not claim full vendor SDK heap elimination; runtime
 *     actor/event/I2C/IRQ hot paths remain zero-heap by project policy.
 */
#ifndef configSUPPORT_STATIC_ALLOCATION
#define configSUPPORT_STATIC_ALLOCATION 1
#endif
#ifndef configSUPPORT_DYNAMIC_ALLOCATION
#define configSUPPORT_DYNAMIC_ALLOCATION 1
#endif
/* EV_FREERTOS_STATIC_ALLOC_CONFIG_END */
FREERTOS_STATIC_ALLOC_CONFIG
  rm -f "$tmp_file"
  trap - HUP INT TERM EXIT
  if ! freertos_static_allocation_config_is_valid "$freertos_config"; then
    echo "error: failed to verify FreeRTOS static allocation config in $freertos_config" >&2
    return 1
  fi
}
ensure_freertos_static_allocation_config
exec "$@"
SDK_STATIC_CONFIG_WRAPPER
}

run_in_image() {
  image="$1"
  shift
  "$DOCKER_BIN" run --rm \
    --user "$RUN_USER" \
    -v "$ROOT_DIR:/work" \
    -w /work \
    "$image" \
    "$@"
}

run_in_image_it() {
  image="$1"
  shift
  "$DOCKER_BIN" run --rm -it \
    --user "$RUN_USER" \
    -v "$ROOT_DIR:/work" \
    -w /work \
    "$image" \
    "$@"
}

run_in_sdk() {
  require_sdk_project
  build_sdk_image
  run_in_image \
    "$SDK_IMAGE" \
    env \
    EV_SDK_PROJECT="$SDK_PROJECT_DIR_REL" \
    ESPPORT="$SDK_SERIAL_PORT" \
    MONITORBAUD="$SDK_MONITOR_BAUD" \
    EV_ESP8266_NET_ENABLE_MQTT="${EV_ESP8266_NET_ENABLE_MQTT:-0}" \
    EV_SDK_IRAM_LIMIT_BYTES="${EV_SDK_IRAM_LIMIT_BYTES:-}" \
    EV_SDK_DRAM_LIMIT_BYTES="${EV_SDK_DRAM_LIMIT_BYTES:-}" \
    EV_SDK_MAX_BSS_BYTES="${EV_SDK_MAX_BSS_BYTES:-}" \
    EV_SDK_MAX_DATA_BYTES="${EV_SDK_MAX_DATA_BYTES:-}" \
    sh -lc "$(sdk_static_config_wrapper_script)" sh "$@"
}

run_in_sdk_it() {
  require_sdk_project
  build_sdk_image
  run_in_image_it \
    "$SDK_IMAGE" \
    env \
    EV_SDK_PROJECT="$SDK_PROJECT_DIR_REL" \
    ESPPORT="$SDK_SERIAL_PORT" \
    MONITORBAUD="$SDK_MONITOR_BAUD" \
    EV_ESP8266_NET_ENABLE_MQTT="${EV_ESP8266_NET_ENABLE_MQTT:-0}" \
    EV_SDK_IRAM_LIMIT_BYTES="${EV_SDK_IRAM_LIMIT_BYTES:-}" \
    EV_SDK_DRAM_LIMIT_BYTES="${EV_SDK_DRAM_LIMIT_BYTES:-}" \
    EV_SDK_MAX_BSS_BYTES="${EV_SDK_MAX_BSS_BYTES:-}" \
    EV_SDK_MAX_DATA_BYTES="${EV_SDK_MAX_DATA_BYTES:-}" \
    sh -lc "$(sdk_static_config_wrapper_script)" sh "$@"
}

run_in_sdk_with_device() {
  require_sdk_project
  require_serial_port
  build_sdk_image

  serial_gid=$(stat -c '%g' "$SDK_SERIAL_PORT" 2>/dev/null || true)

  if [ -n "$serial_gid" ]; then
    "$DOCKER_BIN" run --rm \
      --user "$RUN_USER" \
      --group-add "$serial_gid" \
      --device "$SDK_SERIAL_PORT:$SDK_SERIAL_PORT" \
      -v "$ROOT_DIR:/work" \
      -w /work \
      "$SDK_IMAGE" \
      env \
      EV_SDK_PROJECT="$SDK_PROJECT_DIR_REL" \
      ESPPORT="$SDK_SERIAL_PORT" \
      MONITORBAUD="$SDK_MONITOR_BAUD" \
      FLASH_BEFORE="${FLASH_BEFORE:-$SDK_FLASH_BEFORE}" \
      FLASH_AFTER="${FLASH_AFTER:-$SDK_FLASH_AFTER}" \
      FLASH_RETRIES="${FLASH_RETRIES:-$SDK_FLASH_RETRIES}" \
      FLASH_RETRY_DELAY_S="${FLASH_RETRY_DELAY_S:-$SDK_FLASH_RETRY_DELAY_S}" \
      sh -lc "$(sdk_static_config_wrapper_script)" sh "$@"
  else
    "$DOCKER_BIN" run --rm \
      --user "$RUN_USER" \
      --device "$SDK_SERIAL_PORT:$SDK_SERIAL_PORT" \
