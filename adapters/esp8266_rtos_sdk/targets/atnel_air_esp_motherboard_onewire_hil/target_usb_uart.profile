# Host-side USB-UART profile. This metadata is for tools/fw only;
# it is not an MCU runtime capability and must not be included by firmware.
EV_TARGET_NAME="atnel_air_esp_motherboard_onewire_hil"
EV_TARGET_USB_UART_BRIDGE="FT231X / FTDI-class USB-UART"
EV_TARGET_USB_VID="0403"
EV_TARGET_USB_PID="6015"
EV_TARGET_USB_SERIAL=""
EV_TARGET_SERIAL_BY_ID_PATTERN="*/usb-FTDI*FT231X*"
EV_TARGET_FLASH_BAUD="115200"
EV_TARGET_MONITOR_BAUD="115200"
EV_TARGET_RESET_MODE="default_reset"
EV_TARGET_FLASH_BEFORE="default_reset"
EV_TARGET_FLASH_AFTER="hard_reset"
EV_TARGET_PORT_HINT=""
