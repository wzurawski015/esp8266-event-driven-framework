PROJECT_NAME           = "esp8266-event-driven"
PROJECT_BRIEF          = "Event-driven clean architecture framework in pure C for ESP8266"
OUTPUT_DIRECTORY       = docs/generated
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = NO
ALWAYS_DETAILED_SEC    = YES
INLINE_INHERITED_MEMB  = NO
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_LOGFILE           = docs/generated/doxygen-warnings.log

INPUT                  = README.md \
                         CONTRIBUTING.md \
                         docs \
                         apps \
                         core \
                         domain \
                         ports \
                         adapters \
                         bsp \
                         diag \
                         config
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.c *.md *.def
EXTENSION_MAPPING      = def=C
INCLUDE_PATH           = config
EXCLUDE_PATTERNS       = */docs/generated/site/*

GENERATE_HTML          = YES
HTML_OUTPUT            = site
GENERATE_LATEX         = NO
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = docs/mainpage.md

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
COLLABORATION_GRAPH    = NO
GROUP_GRAPHS           = YES
UML_LOOK               = NO
DOT_MULTI_TARGETS      = YES
DIRECTORY_GRAPH        = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
GRAPHICAL_HIERARCHY    = YES
DOT_GRAPH_MAX_NODES    = 100
